generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum EventType {
  WEDDING
  MEETING
  INCENTIVE
  CONFERENCE
  EXHIBITION
}

enum EventStatus {
  NEGOTIATION
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum VendorEventStatus {
  INVITED
  QUOTED
  ACCEPTED
  REJECTED
}

enum InventoryCategory {
  TECHNICAL
  FURNITURE
  DECOR
  STAFF
  CATERING
  ACCOMMODATION
  FLOOR_SPACE
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  fullName      String
  email         String   @unique
  passwordHash  String

  mobileNumber  String?
  address       String?
  city          String?
  state         String?
  country       String?

  events        Event[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//////////////////////////////////////////////////////
// LOCATION
//////////////////////////////////////////////////////

model Location {
  code      String  @id
  name      String
  country   String

  events Event[] @relation("EventLocation")
  vendors Vendor[]   
}

//////////////////////////////////////////////////////
// EVENT
//////////////////////////////////////////////////////

model Event {
  id            String   @id @default(uuid())
  eventCode     String
  type          EventType
  status        EventStatus @default(NEGOTIATION)

  startDate     DateTime
  endDate       DateTime

  locationCode  String
  creatorId     String

  creator   User     @relation(fields: [creatorId], references: [id])
  location  Location @relation("EventLocation", fields: [locationCode], references: [code])

  operations  EventOperation[]
  allocations EventInventoryAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventCode])
  @@index([creatorId])
}

//////////////////////////////////////////////////////
// EVENT OPERATION
//////////////////////////////////////////////////////

model EventOperation {
  id        String @id @default(uuid())

  eventId   String
  category  InventoryCategory
  metadata  Json?

  finalizedVendorId String?

  event   Event        @relation(fields: [eventId], references: [id])
  vendors EventVendor[]
  allocations EventInventoryAllocation[]

  finalizedVendor Vendor? @relation("FinalizedVendor", fields: [finalizedVendorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, category])
  @@index([eventId])
}

//////////////////////////////////////////////////////
// VENDOR
//////////////////////////////////////////////////////

model Vendor {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  isActive      Boolean  @default(true)

  baseLocationCode String
  baseLocation     Location @relation(fields: [baseLocationCode], references: [code])

  rating        Float   @default(0)
  reviewCount   Int     @default(0)
  starLevel     Int     @default(3)

  inventoryItems InventoryItem[]
  participations EventVendor[]
  allocations    EventInventoryAllocation[]
  finalizedOperations EventOperation[] @relation("FinalizedVendor")
  categories VendorCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorCategory {
  id        String @id @default(uuid())

  vendorId  String
  category  InventoryCategory
  metadata  Json?

  vendor Vendor @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, category])
  @@index([vendorId])
}

//////////////////////////////////////////////////////
// EVENT VENDOR (NEGOTIATION)
//////////////////////////////////////////////////////

model EventVendor {
  id           String @id @default(uuid())

  operationId  String
  vendorId     String

  status            VendorEventStatus @default(INVITED)
  quotedAmount      Float?
  negotiatedAmount  Float?

  operation EventOperation @relation(fields: [operationId], references: [id])
  vendor    Vendor         @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operationId, vendorId])
  @@index([vendorId])
}

//////////////////////////////////////////////////////
// INVENTORY
//////////////////////////////////////////////////////

model InventoryItem {
  id            String   @id @default(uuid())
  vendorId      String
  name          String
  category      InventoryCategory
  totalQuantity Int

  description   String?
  metadata      Json?

  vendor Vendor @relation(fields: [vendorId], references: [id])
  allocations EventInventoryAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
}

//////////////////////////////////////////////////////
// INVENTORY ALLOCATION
//////////////////////////////////////////////////////

model EventInventoryAllocation {
  id                String @id @default(uuid())

  eventId           String
  operationId       String
  inventoryItemId   String
  vendorId          String
  quantityAllocated Int

  event         Event          @relation(fields: [eventId], references: [id])
  operation     EventOperation @relation(fields: [operationId], references: [id])
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operationId, inventoryItemId])
  @@index([vendorId])
  @@index([eventId])
}